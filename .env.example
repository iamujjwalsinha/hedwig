# Supabase — create a project, run supabase/migrations in SQL editor (or use CLI).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Optional canonical / Open Graph URLs in production (include https://, no trailing slash)
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Optional rate limits (recommended for production). Create a Redis database at https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Dev: npm run dev uses port 5000; on macOS, AirPlay often binds 5000 — use npm run dev:5050 instead.
