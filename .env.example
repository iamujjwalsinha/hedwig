# Supabase: create a project, run supabase/migrations in SQL editor (or use CLI).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Canonical site URL for production SEO: metadataBase, og:url, sitemap, robots, social cards.
# Use your primary host (www or apex). Include https://, no trailing slash.
# NEXT_PUBLIC_SITE_URL=https://www.hedwig.app

# Optional rate limits (recommended for production). Create a Redis database at https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Dev: npm run dev uses port 5000; on macOS, AirPlay often binds 5000, so use npm run dev:5050 instead.
